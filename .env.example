# Fireworks AI API Key (optional - system falls back to rule-based diagnosis)
# Get your API key from: https://fireworks.ai/
FIREWORKS_API_KEY=your_api_key_here

# Fireworks Model/Deployment (optional - uses default deployment if not set)
# Examples:
#   FIREWORKS_MODEL=accounts/YOUR_ACCOUNT/deployments/YOUR_DEPLOYMENT
#   FIREWORKS_MODEL=accounts/fireworks/models/gemma-2-9b-it
FIREWORKS_MODEL=

# Backend Port (default: 8080)
PORT=8080

# Frontend API URL
# For local development: http://localhost:8080
# For Docker: http://backend:8080 (internal) or http://localhost:8080 (external)
NEXT_PUBLIC_API_URL=http://localhost:8080
